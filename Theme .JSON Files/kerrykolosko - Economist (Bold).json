{
    "name": "Economist Theme Colours Bold",
    "visualStyles": {
        "page": {
            "*": {
                "background": [
                    {
                        "color": {
                            "solid": {
                                "color": "#FFFFFF"
                            }
                        },
                        "transparency": 0
                    }
                ],
                "outspace": [
                    {
                        "color": {
                            "solid": {
                                "color": "#FFFFFF"
                            }
                        }
                    }
                ]
            }
        },
        "*": {
            "*": {
                "outspacePane": [
                    {
                        "backgroundColor": {
                            "solid": {
                                "color": "#405061"
                            }
                        },
                        "foregroundColor": {
                            "solid": {
                                "color": "#FFFFFF"
                            }
                        }
                    }
                ],
                "filterCard": [
                    {
                        "$id": "Applied",
                        "backgroundColor": {
                            "solid": {
                                "color": {
                                    "expr": {
                                        "ThemeDataColor": {
                                            "ColorId": 3,
                                            "Percent": 1
                                        }
                                    }
                                }
                            }
                        },
                        "foregroundColor": {
                            "solid": {
                                "color": "#FFFFFF"
                            }
                        },
                        "transparency": 0,
                        "inputBoxColor": {
                            "solid": {
                                "color": {
                                    "expr": {
                                        "ThemeDataColor": {
                                            "ColorId": 3,
                                            "Percent": 0
                                        }
                                    }
                                }
                            }
                        }
                    },
                    {
                        "$id": "Available",
                        "backgroundColor": {
                            "solid": {
                                "color": {
                                    "expr": {
                                        "ThemeDataColor": {
                                            "ColorId": 2,
                                            "Percent": 1
                                        }
                                    }
                                }
                            }
                        },
                        "foregroundColor": {
                            "solid": {
                                "color": "#FFFFFF"
                            }
                        },
                        "transparency": 0,
                        "inputBoxColor": {
                            "solid": {
                                "color": {
                                    "expr": {
                                        "ThemeDataColor": {
                                            "ColorId": 2,
                                            "Percent": 0
                                        }
                                    }
                                }
                            }
                        }
                    }
                ],
                "categoryAxis": [
                    {
                        "showAxisTitle": false,
                        "titleFontFamily": "Segoe UI Semibold"
                    }
                ],
                "valueAxis": [
                    {
                        "showAxisTitle": false,
                        "titleFontFamily": "Segoe UI Semibold"
                    }
                ],
                "background": [
                    {
                        "transparency": 100
                    }
                ],
                "visualHeader": [
                    {
                        "transparency": 100
                    }
                ]
            }
        }
    },
    "dataColors": [
        "#E3120B", "#0098A6", "#FFD700", "#2C2C2C", "#8A8B8C", "#005F83", "#B51D60", "#FDBF11"


    ],
    "textClasses": {
        "callout": {
            "fontFace": "'Segoe UI', wf_segoe-ui_normal, helvetica, arial, sans-serif",
            "fontSize": 25
        },
        "title": {
            "fontFace": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
            "fontSize": 10
        }
    }
}
  "visualStyles": {
    "*": {
      "*": {
        "*": [
          {
            "transparency": 0,
            "wordWrap": true
          }
        ],
        "title": [
          {
            "titleWrap": true
          }
        ],
        "lineStyles": [
          {
            "strokeWidth": 2
          }
        ],
        "wordWrap": [
          {
            "show": true
          }
        ],
        "background": [
          {
            "show": false,
            "transparency": 0
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "transparency": 0,
            "foregroundColor": {
              "solid": {
                "color": "#252423"
              }
            },
            "border": true
          },
          {
            "$id": "Available",
            "transparency": 0,
            "foregroundColor": {
              "solid": {
                "color": "#252423"
              }
            },
            "border": true
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "transparency": 0,
            "color": {
              "solid": {
                "color": "#E6E6E6"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#F3F2F1"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#252423"
              }
            },
            "borderColor": {
              "solid": {
                "color": "#E0E0E0"
              }
            },
            "transparency": 0,
            "titleSize": 12,
            "headerSize": 10,
            "fontFamily": "Segoe UI",
            "border": true
          }
        ],
        "background": [
          {
            "transparency": 0,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "image": {
              "name": "Background",
              "scaling": "Fit",
              "url": ""
            }
          }
        ]
      }
    },
    "actionButton": {
      "*": {
        "visualHeader": [
          {
            "show": false
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "icon": [
          {
            "show": true,
            "iconPadding": 8
          },
          {
            "$id": "default",
            "lineColor": {
              "solid": {
                "color": "#808080"
              }
            },
            "lineWeight": 1
          },
          {
            "$id": "hover",
            "lineColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "lineWeight": 2
          },
          {
            "$id": "selected",
            "lineColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "lineWeight": 2
          }
        ],
        "fill": [
          {
            "show": true
          },
          {
            "$id": "default",
            "transparency": 100,
            "fillColor": {
              "solid": {
                "color": "#ffffff"
              }
            }
          },
          {
            "$id": "hover",
            "transparency": 90,
            "fillColor": {
              "solid": {
                "color": "#808080"
              }
            }
          },
          {
            "$id": "selected",
            "transparency": 50,
            "fillColor": {
              "solid": {
                "color": "#808080"
              }
            }
          },
          {
            "$id": "disabled",
            "transparency": 100
          }
        ],
        "outline": [
          {
            "show": false
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "*": [
          {
            "showExpandCollapseButtons": true
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 2,
                      "Percent": 0.4
                    }
                  }
                }
              }
            },
            "transparency": 2
          }
        ]
      }
    },
    "filledMap": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": {
                  "expr": {
                    "ThemeDataColor": {
                      "ColorId": 1,
                      "Percent": 0.4
                    }
                  }
                }
              }
            }
          }
        ]
      }
    },
